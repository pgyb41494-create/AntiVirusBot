DISCORD_TOKEN=your-discord-bot-token

# Railway API URL
API_URL=https://your-api.up.railway.app

# Same BOT_API_KEY as set on AntiVirusAPI
BOT_API_KEY=change-me-bot-secret

# Seconds between polls (default 2)
POLL_INTERVAL=2

# Optional — comma-separated server IDs for instant slash-command sync on deploy
# Right-click your server → Copy Server ID (enable Developer Mode in Discord settings)
GUILD_IDS=123456789012345678
